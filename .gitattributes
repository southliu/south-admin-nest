# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files
*.css text
*.html text
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.xml text
*.yml text
*.yaml text

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
